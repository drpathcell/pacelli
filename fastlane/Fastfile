default_platform(:ios)

# ─── Shared helpers ────────────────────────────────────────────────────────────

def flutter_build_version
  # Parse version from pubspec.yaml e.g. "1.0.0+42"
  pubspec = File.read("../pubspec.yaml")
  version_line = pubspec.match(/^version:\s*(.+)\+(\d+)/)
  {
    name:   version_line[1],
    number: version_line[2].to_i
  }
end

def asc_api_key
  app_store_connect_api_key(
    key_id:        ENV["ASC_KEY_ID"],
    issuer_id:     ENV["ASC_ISSUER_ID"],
    key_content:   ENV["ASC_KEY_CONTENT"],   # .p8 content, not file path
    is_key_content_base64: true,
    in_house:      false
  )
end

# ─── iOS ───────────────────────────────────────────────────────────────────────

platform :ios do

  desc "Sync certificates and provisioning profiles (read-only by default)"
  lane :sync_signing do |options|
    api_key = asc_api_key
    match(
      type:               options[:type] || "appstore",
      readonly:           options.fetch(:readonly, true),
      api_key:            api_key,
      app_identifier:     "com.pacelli.pacelli"
    )
  end

  desc "Build a signed iOS IPA (no upload)"
  lane :build do
    v = flutter_build_version
    api_key = asc_api_key  # sets global Spaceship session for pilot/deliver

    # Match is optional. Without MATCH_GIT_URL we drive Xcode automatic signing
    # by passing ASC API key directly to xcodebuild via -authenticationKey*
    # flags (NOT build_app's :api_key — gym doesn't accept it). For repeat-CI
    # robustness, prefer match: it removes the per-run cert provisioning churn.
    use_match = !ENV["MATCH_GIT_URL"].nil? && !ENV["MATCH_GIT_URL"].empty?

    if use_match
      sync_signing(type: "appstore", readonly: true)
    else
      UI.message("MATCH_GIT_URL unset — using Xcode automatic signing with ASC API key.")
    end

    # Materialize ASC API key to disk so xcodebuild -authenticationKeyPath can read it
    require "base64"
    require "fileutils"
    asc_key_dir = File.expand_path("../tmp_asc", __FILE__)
    FileUtils.mkdir_p(asc_key_dir)
    asc_key_path = File.join(asc_key_dir, "AuthKey_#{ENV['ASC_KEY_ID']}.p8")
    File.binwrite(asc_key_path, Base64.decode64(ENV["ASC_KEY_CONTENT"]))

    sh("flutter build ios --release --no-codesign --build-name=#{v[:name]} --build-number=#{v[:number]}")

    build_options = {
      workspace:        "ios/Runner.xcworkspace",
      scheme:           "Runner",
      configuration:    "Release",
      output_directory: "build/ios",
      output_name:      "Pacelli.ipa",
      export_method:    "app-store"
    }

    if use_match
      build_options[:export_options] = {
        provisioningProfiles: {
          "com.pacelli.pacelli" => "match AppStore com.pacelli.pacelli"
        }
      }
    else
      build_options[:export_options] = { signingStyle: "automatic" }
      auth_args = [
        "-allowProvisioningUpdates",
        "-authenticationKeyIssuerID", ENV["ASC_ISSUER_ID"],
        "-authenticationKeyID",       ENV["ASC_KEY_ID"],
        "-authenticationKeyPath",     asc_key_path
      ].join(" ")
      build_options[:xcargs]        = auth_args  # archive
      build_options[:export_xcargs] = auth_args  # exportArchive
    end

    build_app(build_options)

    # Clean up the on-disk .p8 immediately after build
    File.unlink(asc_key_path) if File.exist?(asc_key_path)
  end

  desc "Build + upload to TestFlight"
  lane :beta do
    api_key = asc_api_key
    build
    upload_to_testflight(
      api_key:           api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false,
      changelog:         changelog_from_git_commits(
        commits_count: 10,
        pretty:        "- %s"
      )
    )
  end

  desc "Submit latest TestFlight build to App Store review"
  lane :release do
    api_key = asc_api_key
    deliver(
      api_key:                 api_key,
      submit_for_review:       true,
      automatic_release:       false,   # manual release after approval
      force:                   true,    # skip HTML preview
      skip_screenshots:        false,
      skip_metadata:           false,
      submission_information: {
        add_id_info_uses_idfa:                   false,
        export_compliance_uses_encryption:        true,
        export_compliance_is_exempt:              false,
        export_compliance_contains_third_party_cryptography: true,
        export_compliance_contains_proprietary_cryptography: false,
      }
    )
  end

  desc "Regenerate certs/profiles (CI: set readonly=false + MATCH_GIT_URL writable)"
  lane :regenerate_signing do
    sync_signing(type: "appstore",     readonly: false)
    sync_signing(type: "development",  readonly: false)
  end

end

# ─── Android ───────────────────────────────────────────────────────────────────

platform :android do

  desc "Build a signed Android AAB"
  lane :build do
    v = flutter_build_version

    # Write key.properties from CI secrets
    key_props = <<~PROPS
      storePassword=#{ENV["ANDROID_STORE_PASSWORD"]}
      keyPassword=#{ENV["ANDROID_KEY_PASSWORD"]}
      keyAlias=#{ENV["ANDROID_KEY_ALIAS"]}
      storeFile=#{ENV["ANDROID_KEYSTORE_PATH"] || "release.keystore"}
    PROPS
    File.write("../android/key.properties", key_props)

    # Write keystore from base64 secret
    if ENV["ANDROID_KEYSTORE_BASE64"]
      require "base64"
      File.binwrite(
        "../android/#{ENV["ANDROID_KEYSTORE_PATH"] || "release.keystore"}",
        Base64.decode64(ENV["ANDROID_KEYSTORE_BASE64"])
      )
    end

    sh(
      "flutter build appbundle --release " \
      "--build-name=#{v[:name]} --build-number=#{v[:number]}"
    )
  end

  desc "Build + upload to Play Store internal track"
  lane :beta do
    build
    upload_to_play_store(
      track:         "internal",
      aab:           "../build/app/outputs/bundle/release/app-release.aab",
      json_key_data: ENV["GOOGLE_PLAY_JSON_KEY"],
      skip_upload_apk:         true,
      skip_upload_metadata:    false,
      skip_upload_changelogs:  false,
      skip_upload_images:      false,
      skip_upload_screenshots: false
    )
  end

  desc "Promote internal build to production"
  lane :release do
    upload_to_play_store(
      track:               "internal",
      track_promote_to:    "production",
      json_key_data:       ENV["GOOGLE_PLAY_JSON_KEY"],
      skip_upload_apk:     true,
      skip_upload_aab:     true,
      skip_upload_metadata: false
    )
  end

end
