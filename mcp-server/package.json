{
  "name": "pacelli-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Pacelli household management app",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pacelli-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index.ts --http"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "firebase-admin": "^13.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
